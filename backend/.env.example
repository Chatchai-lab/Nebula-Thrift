# ============================================================================
# LOCAL DEVELOPMENT ENVIRONMENT
# Copy this to .env and fill in your actual values
# WICHTIG: .env ist gitignored! Secrets sind hier sicher
# ============================================================================

# GitHub Models (AIEngine)
GITHUB_TOKEN=ghp_your_token_here
GITHUB_MODEL_ENDPOINT=https://models.inference.ai.azure.com
GITHUB_MODEL_NAME=Llama-4-Scout-17B-16E-Instruct

# Cosmos DB (CosmosService)
COSMOS_ENDPOINT=https://nebula-thrift-db.documents.azure.com:443/
COSMOS_KEY=your_cosmos_primary_key_here
COSMOS_DATABASE=nebulathrift
COSMOS_CONTAINER=recommendations

# AWS Provider
AWS_PROFILE=default
AWS_REGION=eu-central-1
AWS_ACCESS_KEY_ID=your_aws_access_key
AWS_SECRET_ACCESS_KEY=your_aws_secret_key

# Azure Key Vault (für Production)
KEY_VAULT_URL=https://nebula-thrift-kv.vault.azure.net/

# Application Insights (Observability)
# Set this to enable structured logging telemetry in Azure Functions
APPLICATIONINSIGHTS_CONNECTION_STRING=
